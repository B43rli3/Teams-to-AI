APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8080
LOG_LEVEL=INFO

AZURE_TENANT_ID=
AZURE_CLIENT_ID=

GRAPH_SCOPES=User.Read,ChannelMessage.Read.All,ChannelMessage.Send,offline_access
TEAMS_TEAM_ID=
TEAMS_CHANNEL_ID=

POLL_INTERVAL_SECONDS=10
POLL_PAGE_SIZE=20
PROCESS_BACKLOG=false
BACKLOG_LIMIT=5

TRIGGER_MODE=all
BOT_PREFIX=/ai
BOT_MENTION_ID=

PROCESS_THREAD_REPLIES=false

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_KEEP_ALIVE=10m

LLM_SYSTEM_PROMPT=Du bist ein hilfreicher interner Assistent in Microsoft Teams. Antworte präzise, sachlich und auf Deutsch.
LLM_MAX_CONTEXT_MESSAGES=10
LLM_MAX_RESPONSE_CHARACTERS=12000
LLM_MAX_CONCURRENCY=1

HTTP_MAX_RETRIES=4
HTTP_RETRY_BASE_SECONDS=2

DATABASE_PATH=data/teams_llm.db
TOKEN_CACHE_PATH=data/msal_token_cache.json
