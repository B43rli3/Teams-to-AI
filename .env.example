APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8080
LOG_LEVEL=INFO

AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# offline_access / openid / profile werden von MSAL automatisch hinzugefügt – hier nicht angeben.
# Fuer Team-Kanal inkl. PDF-/Dateianhaenge (SharePoint):
# GRAPH_SCOPES=User.Read,ChannelMessage.Read.All,ChannelMessage.Send,Files.Read.All,Files.ReadWrite
# Fuer Gruppen-Chat inkl. Dateianhaenge (Chat.ReadWrite reicht, kein separates Chat.Read):
# GRAPH_SCOPES=User.Read,Chat.ReadWrite,ChannelMessage.Read.All,ChannelMessage.Send,Files.ReadWrite.All
GRAPH_SCOPES=User.Read,ChannelMessage.Read.All,ChannelMessage.Send,Files.Read.All,Files.ReadWrite

# channel = Team-Kanal | chat = Gruppen-/1:1-Chat
# Bei mehreren Zielen gleichzeitig TEAMS_CHANNELS und/oder TEAMS_CHAT_IDS setzen.
TEAMS_TARGET_MODE=channel
TEAMS_TEAM_ID=
TEAMS_CHANNEL_ID=
TEAMS_CHAT_ID=

# Mehrere Kanäle (Komma-getrennt, Format: teamId|channelId)
# TEAMS_CHANNELS=team-id-1|channel-id-1,team-id-1|channel-id-2
TEAMS_CHANNELS=

# Mehrere Chats (Komma-getrennt)
# TEAMS_CHAT_IDS=19:chat1@thread.v2,19:chat2@thread.v2
TEAMS_CHAT_IDS=

POLL_INTERVAL_SECONDS=10
POLL_PAGE_SIZE=20
PROCESS_BACKLOG=false
BACKLOG_LIMIT=5

# Hinweis: Bei PROCESS_BACKLOG=false markiert der erste Poll je Ziel alle
# vorhandenen Nachrichten nur als gesehen. Offene "queued"-Nachrichten werden
# beim Start verworfen, damit alte Nachrichten nicht nachträglich beantwortet werden.

TRIGGER_MODE=all
BOT_PREFIX=/ai
BOT_MENTION_ID=

PROCESS_THREAD_REPLIES=false

PROCESS_ATTACHMENTS=true
PROCESS_IMAGES=true
PROCESS_DOCUMENTS=true
ATTACHMENT_MAX_FILES=5
ATTACHMENT_MAX_BYTES=10000000
ATTACHMENT_MAX_DOCUMENT_CHARS=30000

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:14b
# Vision-Modell fuer Bildanalyse (empfohlen). Beispiele: qwen2.5vl:7b, llava, llama3.2-vision
OLLAMA_VISION_MODEL=
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_KEEP_ALIVE=10m

LLM_SYSTEM_PROMPT=Du bist ein hilfreicher interner Assistent in Microsoft Teams. Antworte präzise, sachlich und ausschließlich auf Deutsch.
LLM_FORCE_GERMAN_RETRY=true
SEND_PDF_REPLIES=true
LLM_MAX_CONTEXT_MESSAGES=10
LLM_MAX_RESPONSE_CHARACTERS=12000
LLM_MAX_CONCURRENCY=1

HTTP_MAX_RETRIES=4
HTTP_RETRY_BASE_SECONDS=2

DATABASE_PATH=data/teams_llm.db
TOKEN_CACHE_PATH=data/msal_token_cache.json
